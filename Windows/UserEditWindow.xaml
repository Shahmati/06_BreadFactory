<Window x:Class="BreadFactory.Windows.UserEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BreadFactory.Windows"
        mc:Ignorable="d"
        Title="Хлебобулочный завод - добавление" Height="600" Width="450"
        MinHeight="600" MinWidth="450"
        Background="Wheat">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="Фамилия" Style="{StaticResource tblEdit}"/>
            <TextBox x:Name="tbSecondName" Margin="0,5,0,10" Style="{StaticResource tbxLogEdit}"/>
            <TextBlock Text="Имя" Style="{StaticResource tblEdit}"/>
            <TextBox x:Name="tbFirstName" Style="{StaticResource tbxLogEdit}" Margin="0,5,0,10"/>
            <TextBlock Text="Отчество" Style="{StaticResource tblEdit}"/>
            <TextBox x:Name="tbPatronymic" Style="{StaticResource tbxLogEdit}" Margin="0,5,0,10"/>
            <TextBlock Text="Логин" Style="{StaticResource tblEdit}"/>
            <TextBox x:Name="tbLogin" Style="{StaticResource tbxLogEdit}" Margin="0,5,0,10"/>
            <TextBlock Text="Пароль" Style="{StaticResource tblEdit}"/>
            <PasswordBox x:Name="pbPassword" Height="35" Margin="0,5,0,10"/>
            <TextBlock Text="Роль" Style="{StaticResource tblEdit}"/>
            <ComboBox x:Name="cbRole" DisplayMemberPath="RoleName" SelectedValuePath="RoleID" Height="35" Margin="0,5,0,10"/>
            <CheckBox x:Name="chBlocked" Content="Заблокирован" FontSize="18" VerticalContentAlignment="Center"/>
        </StackPanel>
        <Button Grid.Row="1" Content="Сохранить" Style="{StaticResource btnAdmin}" Background="Green" Click="BtnSave_Click"/>
    </Grid>
</Window>
